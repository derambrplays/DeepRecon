# DeepRecon - API Keys
# Copie este arquivo para .env e preencha suas chaves
# As variaveis serao carregadas automaticamente pelo script

# WPScan: token de API (opcional, melhora deteccao de vulnerabilidades)
WPSCAN_API_TOKEN=

# Subfinder/Amass: chaves para descoberta de subdominios
# Crie o arquivo ~/.config/subfinder/provider-config.yaml com essas chaves
# Ou use as variaveis abaixo (se a ferramenta suportar):
# VIRUSTOTAL_API_KEY=
# SHODAN_API_KEY=
# SECURITYTRAILS_API_KEY=
# GITHUB_TOKEN=
